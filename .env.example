# Alibaba Cloud Model Studio (DashScope)
DASHSCOPE_API_KEY=sk-...
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Model IDs
QWEN_CHAT_MODEL=qwen-plus
QWEN_CODER_MODEL=qwen2.5-coder-32b-instruct
QWEN_VL_MODEL=qwen-vl-max
QWEN_AUDIO_MODEL=qwen2-audio-instruct
QWEN_EMBED_MODEL=text-embedding-v3

# Postgres (shared brain - relational store)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=brain
POSTGRES_USER=brain_user
POSTGRES_PASSWORD=changeme

# Qdrant (shared brain - vector store)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
