{
  "id": "820f9614-5023-48f4-b225-2d1b05098038",
  "name": "Local Loop - Review and Code (15 min)",
  "nodes": [
    {
      "id": "ll-1",
      "name": "Every 15 Minutes",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [-400, 0],
      "parameters": {
        "rule": { "interval": [{ "field": "minutes", "minutesInterval": 15 }] }
      }
    },
    {
      "id": "ll-2",
      "name": "Run Local Loop Agent",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [-160, 0],
      "continueOnFail": true,
      "parameters": {
        "command": "cd /home/cbk/qwen-agent-collective && OLLAMA_CODE_MODEL=qwen3-next-cbk:latest python3 agents/local_loop/run.py 2>&1"
      }
    },
    {
      "id": "ll-3",
      "name": "Log Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [80, 0],
      "parameters": {
        "jsCode": "const out = $input.first().json.stdout || '';\nconst success = out.includes('SUCCESS');\nconst committed = out.match(/\\[master [a-f0-9]+\\]/);\nreturn [{ json: { success, committed: committed ? committed[0] : null, output: out.slice(-2000) } }];"
      }
    }
  ],
  "connections": {
    "Every 15 Minutes": { "main": [[{ "node": "Run Local Loop Agent", "type": "main", "index": 0 }]] },
    "Run Local Loop Agent": { "main": [[{ "node": "Log Result", "type": "main", "index": 0 }]] }
  },
  "active": true,
  "settings": { "executionOrder": "v1" }
}
