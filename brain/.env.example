# Alibaba Cloud Model Studio (DashScope) — OpenAI-compatible endpoint
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_CHAT_MODEL=qwen-plus
QWEN_EMBED_MODEL=text-embedding-v3

# Postgres (shared brain — structured store + governance)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=collective
POSTGRES_USER=collective
POSTGRES_PASSWORD=change-me

# Qdrant (shared brain — semantic store)
QDRANT_BASE_URL=http://qdrant:6333
QDRANT_API_KEY=

# n8n (orchestrator exposing retrieve / ingest / manifest)
N8N_HOST=localhost
N8N_PORT=5678

# Defaults
DEFAULT_USER_ID=connor
DEFAULT_AGENT=echo
