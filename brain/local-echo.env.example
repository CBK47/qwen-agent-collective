# Core service URLs
OLLAMA_BASE_URL=http://ollama:11434
QDRANT_BASE_URL=http://qdrant:6333
OPENWEBUI_BASE_URL=http://open-webui:8080
N8N_HOST=localhost
N8N_PORT=5678

# Ollama models
OLLAMA_CHAT_MODEL=qwen3:14b
OLLAMA_SUMMARY_MODEL=gpt-oss:20b
OLLAMA_EMBED_MODEL=embeddinggemma

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=localecho
POSTGRES_USER=localecho
POSTGRES_PASSWORD=change-me

# Qdrant
QDRANT_API_KEY=

# Open WebUI
WEBUI_SECRET_KEY=replace-me

# Langfuse
LANGFUSE_HOST=http://langfuse-web:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Obsidian vault mount
OBSIDIAN_VAULT_PATH=/data/obsidian/local-echo-vault

# Agent defaults
DEFAULT_USER_ID=connor
DEFAULT_AGENT=echo
